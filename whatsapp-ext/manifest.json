{
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "whatsapp-pos-transcriptor@taller.local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "name": "WhatsApp Web Transcriptor",
  "version": "1.0",
  "description": "Scrapes WhatsApp Web messages and sends them to a local server.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://web.whatsapp.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module",
    "scripts": [
      "background.js"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ]
}
